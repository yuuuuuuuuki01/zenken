# ==========================================
# GigaCompute Server - Environment Variables
# ==========================================

# --- Node Environment ---
NODE_ENV=development
PORT=8081

# --- Database ---
# SQLite (Local Development)
# DATABASE_URL="file:./giga.db"
# PostgreSQL (Docker / GCP Cloud SQL)
DATABASE_URL="postgresql://giga:computesecret@db:5432/gigacompute"

# --- Security & Auth ---
# ADMIN_TOKEN="your_secure_random_token_here"
# JWT_SECRET="your_jwt_secret_for_user_auth"

# --- GCP BigQuery Integration ---
BQ_ENABLED=false
BQ_DATASET="gigacompute_analytics"
# GOOGLE_APPLICATION_CREDENTIALS="/app/gcp-service-account.json"

# --- Stripe Integration ---
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
