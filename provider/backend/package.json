{
    "name": "gigacompute-agent",
    "version": "1.3.2",
    "private": true,
    "scripts": {
        "start": "ts-node index.ts",
        "build": "tsc",
        "package": "npm run build && pkg . --out-path ./dist/bin"
    },
    "bin": "dist/provider/backend/index.js",
    "pkg": {
        "assets": [
            "../../frontend/**/*",
            "certs/**/*"
        ],
        "targets": [
            "node18-win-x64",
            "node18-macos-x64",
            "node18-macos-arm64"
        ]
    },
    "dependencies": {
        "@types/os-utils": "^0.0.4",
        "adm-zip": "^0.5.16",
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "jsonwebtoken": "^9.0.0",
        "node-forge": "^1.3.1",
        "os-utils": "^0.0.14",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/node": "^18.0.0",
        "@types/ws": "^8.18.1",
        "pkg": "^5.8.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.0"
    }
}