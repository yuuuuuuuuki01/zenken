{
    "name": "vscode-gigacompute",
    "displayName": "GigaCompute Client",
    "description": "Submit code selections and tasks directly to the GigaCompute Network.",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "gigacompute.setApiKey",
                "title": "GigaCompute: Setup API Key"
            },
            {
                "command": "gigacompute.submitSelection",
                "title": "GigaCompute: Submit Code Selection"
            }
        ],
        "configuration": {
            "title": "GigaCompute",
            "properties": {
                "gigacompute.serverUrl": {
                    "type": "string",
                    "default": "http://localhost:8081",
                    "description": "URL of the GigaCompute Server (e.g. https://api.gigacompute.net)"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3",
        "esbuild": "^0.18.11"
    },
    "dependencies": {
        "axios": "^1.6.0"
    }
}